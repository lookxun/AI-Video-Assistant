OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5

# 本地 Docker PostgreSQL 默认连接串；正式部署时换成线上数据库连接串。
DATABASE_URL="postgresql://flashmuse:flashmuse_dev_password@localhost:5432/flashmuse?schema=public"

# 登录 Cookie / 验证码哈希密钥。请在本地和线上改成一串长随机字符串。
AUTH_SECRET=

# 后台管理员邮箱白名单，多个邮箱用英文逗号分隔。
ADMIN_EMAILS=

# SMTP 邮箱验证码。网易 163 示例：smtp.163.com / 465 / true。
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Seedance 独立聚合接口当前本地 MVP 暂停使用，后续部署服务器加白后再配置。
SEEDANCE_BASE_URL=
SEEDANCE_PROJECT_CODE=
SEEDANCE_ACCESS_KEY=
SEEDANCE_SECRET_KEY=
